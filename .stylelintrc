{
  "plugins": ["stylelint-scss"],
  "extends": ["stylelint-config-wordpress/scss", "stylelint-config-prettier"],
  "ignoreFiles": [
    "src/sass/external/**/*.scss",
    "src/sass/foundation/_reset.scss",
    "src/sass/foundation/_form.scss"
  ],
  "rules": {
    "color-hex-length": "short",
    "color-no-invalid-hex": true,
    "indentation": 2,
    "length-zero-no-unit": true,
    "media-feature-name-no-vendor-prefix": true,
    "number-leading-zero": "never",
    "string-quotes": "single",
    "unit-no-unknown": [true, { "ignoreUnits": ["dvh", "dvw"] }],
    "block-no-empty": null,
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "function-url-quotes": null,
    "scss/selector-no-redundant-nesting-selector": null,
    "max-line-length": [
      300,
      {
        "ignore": "non-comments",
        "ignorePattern": ["/(https?://[0-9,a-z]*.*)|(^description\\:.+)|(^tags\\:.+)/i"]
      }
    ]
  }
}
